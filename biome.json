{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noAssignInExpressions": "warn",
        "noArrayIndexKey": "warn"
      },
      "a11y": {
        "useButtonType": "warn",
        "useSemanticElements": "warn",
        "useKeyWithClickEvents": "warn",
        "noAutofocus": "warn",
        "noNoninteractiveTabindex": "warn",
        "noLabelWithoutControl": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "ignore": [
      "**/node_modules",
      "**/out",
      "**/dist",
      "archive/**",
      "packages/desktop/src-tauri/target",
      "packages/desktop/src-tauri/gen",
      "engine/build",
      "bun.lock",
      "bun.lockb"
    ]
  }
}
