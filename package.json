{
  "name": "singularity",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "description": "A full-featured digital audio workstation and creative IDE.",
  "repository": {
    "type": "git",
    "url": "https://github.com/marius-patrik/singularity.git"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter '*' dev",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,js,json,md,yml,yaml}": ["biome check --write --no-errors-on-unmatched"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.7.0"
  }
}
