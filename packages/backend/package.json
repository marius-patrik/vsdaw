    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.0",
    "@singularity/shared": "workspace:*",
    "fastify": "^5.0.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
