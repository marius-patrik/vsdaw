{
  "name": "@singularity/ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": ["*.css"],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./tailwind.preset": {
      "types": "./dist/tailwind.preset.d.ts",
      "default": "./dist/tailwind.preset.js"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "tsc --build tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test src/__tests__"
  },
  "dependencies": {
    "@singularity/shared": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "monaco-editor": "^0.50.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
